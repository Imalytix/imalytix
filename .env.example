# ─────────────────────────────────────────
# Imalytix 환경 변수 템플릿
# 복사 후 .env 로 저장하고 값을 채워주세요.
# ─────────────────────────────────────────

# ── OpenAI (비전 분석) ──────────────────
OPENAI_API_KEY=
OPENAI_VISION_MODEL=gpt-4.1-mini

# ── Gemini (앙상블 비전 분석) ──────────
# 발급: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=
GEMINI_VISION_MODEL=gemini-2.0-flash

# ── 샘플 이미지 다운로드 ─────────────────
# Unsplash API 키 발급: https://unsplash.com/developers
UNSPLASH_ACCESS_KEY=

# Pexels API 키 발급: https://www.pexels.com/api/
PEXELS_API_KEY=

# ── 백엔드 설정 ──────────────────────────
MAX_FILE_SIZE_MB=10
IMAGE_LONG_SIDE=1024
REQUEST_TIMEOUT_SECONDS=60
APP_ENV=local
LOG_LEVEL=INFO
MOCK_VISION_FALLBACK=false
ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
