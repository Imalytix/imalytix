# ─────────────────────────────────────────────────────
# Imalytix 환경 변수 템플릿
# 로컬: 이 파일을 .env 로 복사 후 값을 채우세요.
# 배포: Railway / Vercel 대시보드에서 직접 환경변수 입력
# ─────────────────────────────────────────────────────

# ── Vision LLM API Keys (최소 1개 이상 필수) ─────────
OPENAI_API_KEY=sk-...
OPENAI_VISION_MODEL=gpt-4.1-mini

GEMINI_API_KEY=
GEMINI_VISION_MODEL=gemini-2.5-flash

ANTHROPIC_API_KEY=sk-ant-...
ANTHROPIC_VISION_MODEL=claude-haiku-4-5-20251001

# ── AI 탐지기 (선택) ─────────────────────────────────

# ── 서버 설정 ────────────────────────────────────────
APP_ENV=local
LOG_LEVEL=INFO
LOG_DIR=logs
LOG_FILE=logs/imalytix.log
ANALYSIS_LOG_FILE=logs/analysis.log
LOG_MAX_BYTES=5242880
LOG_BACKUP_COUNT=5
ANALYSIS_SLOW_THRESHOLD_MS=3000
MAX_FILE_SIZE_MB=10
IMAGE_LONG_SIDE=1024
REQUEST_TIMEOUT_SECONDS=60
MOCK_VISION_FALLBACK=false
PHASH_CACHE_ENABLED=true
PHASH_DB_PATH=data/phash_cache.sqlite3
PHASH_SIMILARITY_THRESHOLD=6
EMBEDDING_STORE_ENABLED=true
EMBEDDING_DB_PATH=data/embedding_store.sqlite3
EMBEDDING_TOP_K=5

# ── 실제 DINOv2 / OpenCLIP 임베딩 (Phase B, 선택) ─────
# real 로 바꾸면 최초 실행 시 모델 가중치를 다운로드합니다(수백 MB).
# 팀 검토 후 켜세요. 기본값은 기존 legacy(경량 baseline) 유지.
EMBEDDING_MODEL_BACKEND=legacy
DINOV2_MODEL_NAME=facebook/dinov2-small
CLIP_MODEL_NAME=ViT-B-32
CLIP_PRETRAINED_TAG=openai
EMBEDDING_DEVICE=cpu

# 임베딩 유사도가 매우 높을 때 quick 모드에서 LLM 호출을 생략할지 여부.
# 기본 OFF. 켜기 전 팀 검토 필요(잘못된 라벨 재사용 위험).
EMBEDDING_ROUTING_SHORTCUT_ENABLED=false
EMBEDDING_STRONG_SIMILARITY_THRESHOLD=0.97

# ── CORS ─────────────────────────────────────────────
# 로컬: 아래 값 그대로
# 배포: 실제 프론트엔드 URL로 변경 (예: https://imalytix.vercel.app)
ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
