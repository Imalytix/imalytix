# ─────────────────────────────────────────────────────
# Imalytix 환경 변수 템플릿
# 로컬: 이 파일을 .env 로 복사 후 값을 채우세요.
# 배포: Railway / Vercel 대시보드에서 직접 환경변수 입력
# ─────────────────────────────────────────────────────

# ── Vision LLM API Keys (최소 1개 이상 필수) ─────────
OPENAI_API_KEY=sk-...
OPENAI_VISION_MODEL=gpt-4.1-mini

GEMINI_API_KEY=
GEMINI_VISION_MODEL=gemini-2.5-flash

ANTHROPIC_API_KEY=sk-ant-...
ANTHROPIC_VISION_MODEL=claude-haiku-4-5-20251001

# ── AI 탐지기 (선택) ─────────────────────────────────
# Hive AI V2 Project Key (Playground 키는 미지원)
HIVE_API_KEY=

# ── 서버 설정 ────────────────────────────────────────
APP_ENV=local
LOG_LEVEL=INFO
MAX_FILE_SIZE_MB=10
IMAGE_LONG_SIDE=1024
REQUEST_TIMEOUT_SECONDS=60
MOCK_VISION_FALLBACK=false

# ── CORS ─────────────────────────────────────────────
# 로컬: 아래 값 그대로
# 배포: 실제 프론트엔드 URL로 변경 (예: https://imalytix.vercel.app)
ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
